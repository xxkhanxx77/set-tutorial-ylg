# You do NOT need this file to READ the course — every notebook already has its results saved.
# Credentials are only required if you want to RE-RUN a notebook yourself.
#
#   Steps 1 & 3  -> need Settrade API keys (TFEX candle reference) + internet
#   Steps 2 & 4  -> need DATABASE_URL (a PostgreSQL DB the data logger has filled)
#
# Copy this file to .env and fill in the values.

# --- Settrade Open API (TFEX USD futures candles) ---
SETTRADE_ENV=prod
SETTRADE_APP_ID=your_app_id
SETTRADE_APP_SECRET=your_app_secret
SETTRADE_APP_CODE=ALGO
SETTRADE_BROKER_ID=your_broker_id
SETTRADE_ACCOUNT_NO=your_tfex_account_no

# --- PostgreSQL holding the captured bid/ask (see THE_DATA_LOGGER.md) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
